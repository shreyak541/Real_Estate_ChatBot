# =============================================================================
# Seabreeze Real Estate Chatbot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Provider (set at least ONE)
# ---------------------------------------------------------------------------

# Option A: OpenAI (recommended)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini          # or gpt-4o for better quality

# Option B: Google Gemini (alternative)
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-flash-latest

# ---------------------------------------------------------------------------
# Database backend
# ---------------------------------------------------------------------------

DB_BACKEND=csv        # "csv" (default) or "sqlite"

# ---------------------------------------------------------------------------
# App settings
# ---------------------------------------------------------------------------

LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR

# ---------------------------------------------------------------------------
# FastAPI server (only needed when running the API separately)
# ---------------------------------------------------------------------------

API_HOST=0.0.0.0
API_PORT=8000
